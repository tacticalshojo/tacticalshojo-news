---
// 💡 1. 引入全域樣式檔
import '../styles/global.css';

// 💡 2. 採用 Astro 內建本地內容引擎
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const allAuthors = await getCollection('authors');

// 建立作者對照表
const authorMap = Object.fromEntries(allAuthors.map(a => [a.id, a.data]));

// 根據日期排序文章（最新發布的在最前面）
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 根據後台勾選的布林值進行區塊分流
const heroPosts = sortedPosts.filter(p => p.data.isHeroBanner);
const hotTopicPosts = sortedPosts.filter(p => p.data.isHotTopic);
const featuredPosts = sortedPosts.filter(p => p.data.isFeatured);
const latestPosts = sortedPosts.slice(0, 12); // 首頁展示最新 12 篇

const currentYear = new Date().getFullYear();

// 🛰️ 注入安全的前端搜尋資料橋樑（提取標題、摘要與路徑）
const searchBridge = sortedPosts.map(post => ({
  title: post.data.title || "",
  summary: post.data.summary || "",
  slug: post.slug
}));
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>戰術少女研究室 | TACTICAL SHOJO NEWS</title>

		<!-- ⚡ 將 Astro 資料拋給前端搜尋引擎的全域變數 -->
		<script define:vars={{ searchBridge }}>
			window.__TACTICAL_POSTS__ = searchBridge;
		</script>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">

		<!-- 🛰️ 戰術改裝：Logo 完全貼齊、標題與導覽列完美右移之進階 Header -->
		<header class="bg-[#003764] text-white sticky top-0 z-50 shadow-lg border-b-2 border-pink-600">
			
			<!-- 上半部：Logo、標題與搜尋欄 -->
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center min-h-[76px] gap-4 border-b border-blue-900/50 pr-4">
				
				<!-- 【左側】Logo 直擊：高度徹底拉滿 h-[76px]，上下完全貼齊邊框 -->
				<div class="flex items-center flex-shrink-0">
					<a href="/" class="flex items-center h-[76px] overflow-hidden group">
						<img 
							src="/images/uploads/戰術少女組-大頭貼.png" 
							alt="戰術少女研究室 Logo" 
							class="w-[76px] h-[76px] object-cover group-hover:scale-105 transition-transform" 
						/>
					</a>
				</div>

				<!-- 【重點改裝】使用 md:ml-auto，把「網站標題與導覽列」整塊推往右側對齊 -->
				<div class="flex flex-col md:flex-row items-center gap-4 w-full md:w-auto md:ml-auto">
					
					<!-- 網站標題 -->
					<a href="/" class="text-2xl font-black tracking-widest text-pink-500 whitespace-nowrap">
						<span>戰術少女<span class="text-white">研究室</span></span>
					</a>

					<!-- 搜尋欄基地 -->
					<div class="relative w-full md:w-72 flex-shrink-0">
						<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400 text-xs">
							⚡
						</div>
						<input 
							type="text" 
							id="tactical-search"
							placeholder="搜尋軍事戰略、戰術自訓..." 
							class="w-full bg-blue-950/60 text-xs text-slate-200 pl-8 pr-4 py-2.5 rounded border border-blue-900/60 focus:outline-none focus:border-pink-500 placeholder-slate-400 transition-all font-medium" 
						/>
						
						<!-- 搜尋結果彈出懸浮視窗 -->
						<div id="search-results" class="absolute right-0 top-full mt-2 w-full sm:w-80 bg-white border border-slate-200 rounded-xl shadow-2xl overflow-hidden hidden z-50 text-slate-900">
							<div class="bg-slate-50 px-3 py-2 border-b border-slate-100 text-[10px] font-bold text-slate-400 uppercase tracking-wider">
								搜尋情報結果
							</div>
							<ul id="results-list" class="divide-y divide-slate-100 max-h-60 overflow-y-auto">
								<!-- 結果由 JS 即時渲染 -->
							</ul>
						</div>
					</div>

				</div>
			</div>

			<!-- 下半部：導覽選單（同步向右對齊） -->
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-end text-sm font-bold py-3 px-4 gap-2">
				<nav class="flex space-x-6 whitespace-nowrap lg:mr-6">
					<a href="/" class="text-pink-500">首頁通報</a>
					<a href="/category/軍事戰略" class="hover:text-pink-400 transition-colors">軍事戰略</a>
					<a href="/category/全民防衛" class="hover:text-pink-400 transition-colors">全民防衛</a>
					<a href="/category/戰術自訓" class="hover:text-pink-400 transition-colors">戰術自訓</a>
					<a href="/category/軍工產業" class="hover:text-pink-400 transition-colors">軍工產業</a>
					<a href="/category/軍風搜奇" class="hover:text-pink-400 transition-colors">軍風搜奇</a>
				</nav>
				{hotTopicPosts.length > 0 && (
					<div class="flex items-center gap-2 text-xs bg-pink-600 px-3 py-1 rounded-full text-white animate-pulse mt-2 lg:mt-0 flex-shrink-0">
						<span>🔥 焦點特報：</span>
						<a href={`/blog/${hotTopicPosts[0].slug}`} class="underline font-medium">{hotTopicPosts[0].data.title}</a>
					</div>
				)}
			</div>
		</header>

		<div class="max-w-7xl mx-auto px-4 my-4">
			<div class="bg-slate-200 border border-slate-300 text-slate-400 text-xs text-center py-4 rounded tracking-widest font-mono">
				【廣告版面 PRE-SLOT / SUPPORT GOOGLE ADSENSE】
			</div>
		</div>

		<main class="max-w-7xl mx-auto px-4 my-8">
			<!-- 🎯 全自動戰術無縫輪播大圖區 -->
			{heroPosts.length > 0 && (
				<section class="mb-12 relative group overflow-hidden rounded-lg shadow-2xl" id="hero-carousel">
					<!-- 1. 輪播主體視窗 -->
					<div class="hero-slider-container relative min-h-[400px] md:min-h-[450px] w-full overflow-hidden">
						<div class="hero-slider flex w-full h-full absolute inset-0 transition-transform duration-500 ease-out select-none">
							{heroPosts.map((post, index) => (
								<div class="hero-slide flex-shrink-0 w-full h-full relative flex items-end bg-slate-900" data-index={index}>
									{post.data.heroImage && (
										<img src={post.data.heroImage} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover opacity-60 pointer-events-none" />
									)}
									<div class="relative p-6 md:p-12 text-white bg-gradient-to-t from-slate-950 via-slate-900/70 to-transparent w-full z-10">
										<span class="bg-pink-600 text-xs px-3 py-1 rounded font-bold tracking-wider mb-4 inline-block">{post.data.category}</span>
										<h1 class="text-2xl md:text-5xl font-black mb-4 tracking-tight">
											<a href={`/blog/${post.slug}`} class="hover:text-pink-400 transition">{post.data.title}</a>
										</h1>
										<p class="text-slate-300 text-xs md:text-sm max-w-3xl line-clamp-2">{post.data.summary}</p>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- 2. 左右戰術切換箭頭（滑鼠滑入時顯現） -->
					{heroPosts.length > 1 && (
						<>
							<button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-slate-950/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 z-20 font-bold shadow-md">❮</button>
							<button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 bg-slate-950/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 z-20 font-bold shadow-md">❯</button>
						</>
					)}

					<!-- 3. 下方導覽進度圓點 -->
					{heroPosts.length > 1 && (
						<div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2 z-20">
							{heroPosts.map((_, index) => (
								<button class="carousel-dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index={index}></button>
							))}
						</div>
					)}
				</section>

				<!-- 4. 輪播控制指令 -->
				<script is:inline>
					function initHeroCarousel() {
						const section = document.getElementById('hero-carousel');
						if (!section) return;

						const slider = section.querySelector('.hero-slider');
						const slides = section.querySelectorAll('.hero-slide');
						const prevBtn = document.getElementById('carousel-prev');
						const nextBtn = document.getElementById('carousel-next');
						const dots = section.querySelectorAll('.carousel-dot');
						
						let currentIndex = 0;
						const totalSlides = slides.length;
						let autoPlayTimer = null;

						if (slider && totalSlides > 1) {
							const goToSlide = (index) => {
								if (index < 0) index = totalSlides - 1;
								if (index >= totalSlides) index = 0;
								currentIndex = index;
								
								slider.style.transform = `translateX(-${currentIndex * 100}%)`;
								
								dots.forEach((dot, idx) => {
									if (idx === currentIndex) {
										dot.classList.remove('bg-white/40', 'w-2');
										dot.classList.add('bg-pink-500', 'w-5');
									} else {
										dot.classList.remove('bg-pink-500', 'w-5');
										dot.classList.add('bg-white/40', 'w-2');
									}
								});
							};

							prevBtn?.addEventListener('click', () => { resetAutoPlay(); goToSlide(currentIndex - 1); });
							nextBtn?.addEventListener('click', () => { resetAutoPlay(); goToSlide(currentIndex + 1); });

							dots.forEach((dot, idx) => {
								dot.addEventListener('click', () => {
									resetAutoPlay();
									goToSlide(idx);
								});
							});

							const startAutoPlay = () => {
								autoPlayTimer = setInterval(() => {
									goToSlide(currentIndex + 1);
								}, 5000);
							};

							const resetAutoPlay = () => {
								clearInterval(autoPlayTimer);
								startAutoPlay();
							};

							goToSlide(0);
							startAutoPlay();
						}
					}

					document.addEventListener('DOMContentLoaded', initHeroCarousel);
					initHeroCarousel();
				</script>
			)}

			<section>
				<h2 class="text-xl font-black border-l-4 border-pink-600 pl-3 mb-6 tracking-wider text-slate-900">
					📡 最新戰術通報
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{latestPosts.map(post => {
						const author = authorMap[post.data.authors?.[0]] || { name: '編輯部' };
						return (
							<article class="bg-white rounded border border-slate-200 shadow-sm overflow-hidden flex flex-col hover:shadow-md transition">
								{post.data.heroImage && (
									<div class="h-48 overflow-hidden bg-slate-100">
										<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover hover:scale-105 transition duration-300" />
									</div>
								)}
								<div class="p-5 flex-1 flex flex-col justify-between">
									<div>
										<span class="text-xs font-bold text-pink-600 tracking-wider uppercase mb-2 block">{post.data.category}</span>
										<h3 class="font-bold text-lg text-slate-900 mb-2 line-clamp-2 hover:text-pink-600">
											<a href={`/blog/${post.slug}`}>{post.data.title}</a>
										</h3>
										<p class="text-slate-500 text-xs line-clamp-3 mb-4">{post.data.summary}</p>
									</div>
									<div class="flex items-center justify-between text-[11px] text-slate-400 pt-3 border-t border-slate-100">
										<span class="font-medium">✍️ {author.name}</span>
										<time>
											{post.data.date instanceof Date 
												? post.data.date.toISOString().split('T')[0] 
												: String(post.data.date).split(' ')[0]}
										</time>
									</div>
								</div>
							</article>
						);
					})}
				</div>
			</section>
		</main>

		<footer class="bg-[#003764] text-slate-300 border-t border-blue-900 text-xs mt-20 pt-10 pb-8">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6 border-b border-blue-900/50 pb-6 mb-6">
				<div class="text-center md:text-left flex flex-col md:flex-row items-center gap-3">
					<img 
						src="/images/uploads/戰術少女組-大頭貼.png" 
						alt="戰術少女研究室 Footer Logo" 
						class="w-10 h-10 rounded-lg shadow object-cover brightness-95 border border-blue-800" 
					/>
					<div>
						<p class="text-sm font-black text-white tracking-widest uppercase mb-1">戰術少女研究室</p>
						<p class="text-[11px] text-blue-300/60 font-mono">TACTICAL SHOJO NEWS // CIVIL DEFENSE INTELLIGENCE</p>
					</div>
				</div>
				<div class="flex flex-wrap justify-center gap-x-6 gap-y-2 font-medium">
					<a href="/about" class="hover:text-pink-400 transition">關於我們</a>
					<a href="/contact" class="hover:text-pink-400 transition">聯繫我們</a>
					<a href="/privacy" class="hover:text-pink-400 transition">隱私政策</a>
					<a href="/terms" class="hover:text-pink-400 transition">服務條款</a>
					<a href="/cookie-policy" class="hover:text-pink-400 transition">Cookie 政策</a>
				</div>
			</div>
			<div class="text-center text-[11px] text-blue-300/50">
				<p>© {currentYear} 戰術少女研究室 TACTICAL SHOJO NEWS. All Rights Reserved.</p>
			</div>
		</footer>

		<!-- 🛰️ 純前端即時搜尋欄驅動腳本 -->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const searchInput = document.getElementById('tactical-search');
				const searchResults = document.getElementById('search-results');
				const resultsList = document.getElementById('results-list');

				if (!searchInput || !searchResults || !resultsList) return;

				document.addEventListener('click', (e) => {
					if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
						searchResults.classList.add('hidden');
					}
				});

				searchInput.addEventListener('input', (e) => {
					const keyword = e.target.value.toLowerCase().trim();
					
					if (keyword.length < 1) {
						searchResults.classList.add('hidden');
						return;
					}

					const posts = window.__TACTICAL_POSTS__ || [];
					
					const filtered = posts.filter(post => 
						post.title.toLowerCase().includes(keyword) || 
						post.summary.toLowerCase().includes(keyword)
					).slice(0, 5);

					resultsList.innerHTML = '';

					if (filtered.length === 0) {
						resultsList.innerHTML = `
							<li class="px-4 py-3 text-xs text-slate-400 text-center font-medium">
								❌ 未尋獲相關戰術通報
							</li>`;
					} else {
						filtered.forEach(post => {
							const li = document.createElement('li');
							li.innerHTML = `
								<a href="/blog/${post.slug}" class="block px-4 py-2.5 hover:bg-slate-50 transition-colors group">
									<div class="text-xs font-bold text-slate-900 group-hover:text-pink-600 transition-colors line-clamp-1">${post.title}</div>
									<div class="text-[10px] text-slate-400 mt-0.5 line-clamp-1">${post.summary}</div>
								</a>
							`;
							resultsList.appendChild(li);
						});
					}

					searchResults.classList.remove('hidden');
				});
			});
		</script>
	</body>
</html>