---
// 💡 1. 引入全域樣式檔
import '../styles/global.css';

// 💡 2. 採用 Astro 內建本地內容引擎
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const allAuthors = await getCollection('authors');

// 建立作者對照表
const authorMap = Object.fromEntries(allAuthors.map(a => [a.id, a.data]));

// 根據日期排序文章（最新發布的在最前面）
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 根據後台勾選的布林值進行區塊分流
const heroPosts = sortedPosts.filter(p => p.data.isHeroBanner);
const hotTopicPosts = sortedPosts.filter(p => p.data.isHotTopic);
const featuredPosts = sortedPosts.filter(p => p.data.isFeatured);
const latestPosts = sortedPosts.slice(0, 12); // 首頁展示最新 12 篇

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>戰術少女研究室 | TACTICAL SHOJO NEWS</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">

		<header class="bg-[#003764] text-white sticky top-0 z-50 shadow-lg border-b-2 border-pink-600">
			<div class="max-w-7xl mx-auto px-4">
				<div class="flex flex-col md:flex-row justify-between items-center py-4 gap-4 border-b border-blue-900/50">
					<a href="/" class="text-2xl font-black tracking-widest text-pink-500 flex items-center gap-3">
						<img src="/logo-avatar.png" alt="戰術少女研究室 Logo" class="w-9 h-9 rounded shadow-md object-cover" />
						<span>戰術少女<span class="text-white">研究室</span></span>
					</a>
					<div class="relative w-full md:w-72">
						<input type="text" placeholder="搜尋軍事戰略、戰術自訓..." class="w-full bg-blue-950/60 text-xs text-slate-200 pl-4 pr-10 py-2.5 rounded border border-blue-900/60 focus:outline-none focus:border-pink-500" />
						<span class="absolute right-3 top-2.5 text-slate-400">🔍</span>
					</div>
				</div>
				<nav class="flex flex-wrap items-center justify-between text-sm font-bold py-3 overflow-x-auto">
					<div class="flex space-x-6 whitespace-nowrap">
						<a href="/" class="text-pink-500">首頁通報</a>
						<a href="/category/軍事戰略" class="hover:text-pink-400">軍事戰略</a>
						<a href="/category/全民防衛" class="hover:text-pink-400">全民防衛</a>
						<a href="/category/戰術自訓" class="hover:text-pink-400">戰術自訓</a>
						<a href="/category/軍工產業" class="hover:text-pink-400">軍工產業</a>
						<a href="/category/軍風搜奇" class="hover:text-pink-400">軍風搜奇</a>
					</div>
					{hotTopicPosts.length > 0 && (
						<div class="flex items-center gap-2 text-xs bg-pink-600 px-3 py-1 rounded-full text-white animate-pulse mt-2 lg:mt-0">
							<span>🔥 焦點特報：</span>
							<a href={`/blog/${hotTopicPosts[0].slug}`} class="underline font-medium">{hotTopicPosts[0].data.title}</a>
						</div>
					)}
				</nav>
			</div>
		</header>

		<div class="max-w-7xl mx-auto px-4 my-4">
			<div class="bg-slate-200 border border-slate-300 text-slate-400 text-xs text-center py-4 rounded tracking-widest font-mono">
				【廣告版面 PRE-SLOT / SUPPORT GOOGLE ADSENSE】
			</div>
		</div>

		<main class="max-w-7xl mx-auto px-4 my-8">
			{heroPosts.length > 0 && (
				<section class="mb-12 relative group overflow-hidden rounded-lg shadow-2xl" id="hero-carousel">
					<div class="hero-slider-container relative min-h-[400px] md:min-h-[450px] w-full overflow-hidden">
						<div class="hero-slider flex w-full h-full absolute inset-0 transition-transform duration-500 ease-out select-none">
							{heroPosts.map((post, index) => (
								<div class="hero-slide flex-shrink-0 w-full h-full relative flex items-end bg-slate-900" data-index={index}>
									{post.data.heroImage && (
										<img src={post.data.heroImage} alt={post.data.title} class="absolute inset-0 w-full h-full object-cover opacity-60 pointer-events-none" />
									)}
									<div class="relative p-6 md:p-12 text-white bg-gradient-to-t from-slate-950 via-slate-900/70 to-transparent w-full z-10">
										<span class="bg-pink-600 text-xs px-3 py-1 rounded font-bold tracking-wider mb-4 inline-block">{post.data.category}</span>
										<h1 class="text-2xl md:text-5xl font-black mb-4 tracking-tight">
											<a href={`/blog/${post.slug}`} class="hover:text-pink-400 transition">{post.data.title}</a>
										</h1>
										<p class="text-slate-300 text-xs md:text-sm max-w-3xl line-clamp-2">{post.data.summary}</p>
									</div>
								</div>
							))}
						</div>
					</div>

					{heroPosts.length > 1 && (
						<>
							<button id="carousel-prev" class="absolute left-4 top-1/2 -translate-y-1/2 bg-slate-950/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 z-20 font-bold shadow-md">❮</button>
							<button id="carousel-next" class="absolute right-4 top-1/2 -translate-y-1/2 bg-slate-950/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300 z-20 font-bold shadow-md">❯</button>
						</>
					)}

					{heroPosts.length > 1 && (
						<div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2 z-20">
							{heroPosts.map((_, index) => (
								<button class="carousel-dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index={index}></button>
							))}
						</div>
					)}
				</section>

				<script is:inline>
					function initHeroCarousel() {
						const section = document.getElementById('hero-carousel');
						if (!section) return;

						const slider = section.querySelector('.hero-slider');
						const slides = section.querySelectorAll('.hero-slide');
						const prevBtn = document.getElementById('carousel-prev');
						const nextBtn = document.getElementById('carousel-next');
						const dots = section.querySelectorAll('.carousel-dot');
						
						let currentIndex = 0;
						const totalSlides = slides.length;
						let autoPlayTimer = null;

						if (slider && totalSlides > 1) {
							const goToSlide = (index) => {
								if (index < 0) index = totalSlides - 1;
								if (index >= totalSlides) index = 0;
								currentIndex = index;
								
								// 物理平移滑軌
								slider.style.transform = `translateX(-${currentIndex * 100}%)`;
								
								// 更新圓點
								dots.forEach((dot, idx) => {
									if (idx === currentIndex) {
										dot.classList.remove('bg-white/40', 'w-2');
										dot.classList.add('bg-pink-500', 'w-5');
									} else {
										dot.classList.remove('bg-pink-500', 'w-5');
										dot