---
import { getCollection } from 'astro:content';

// 撈取所有部落格文章並依照日期排序
const allBlogEntries = await getCollection('blog');
const sortedPosts = allBlogEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// 篩選出有設定為精選（featured）或直接拿最新 3 篇作為輪播特報
const featuredPosts = sortedPosts.filter(post => post.data.featured === true).slice(0, 3);
// 如果沒有文章設為 featured，就自動抓最新的 3 篇文章來輪播
const carouselPosts = featuredPosts.length > 0 ? featuredPosts : sortedPosts.slice(0, 3);

const currentYear = new Date().getFullYear();

// 衛星搜尋橋樑資料
const searchBridge = sortedPosts.map(post => ({
  title: post.data.title || "",
  summary: post.data.summary || "",
  slug: post.slug
}));
---

<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>戰術少女研究室 | 戰術、民防與情報通報首頁</title>
		
		<script define:vars={{ searchBridge }}>
			window.__TACTICAL_POSTS__ = searchBridge;
		</script>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased min-h-screen flex flex-col">
		
		<!-- 🛰️ 戰術大頭標頭 -->
		<header class="bg-[#003764] text-white sticky top-0 z-50 shadow-lg border-b-2 border-pink-600">
			<div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center min-h-[76px] gap-4 border-b border-blue-900/50 pr-4">
				<div class="flex items-center flex-shrink-0">
					<a href="/" class="flex items-center h-[76px] overflow-hidden group">
						<img src="/images/uploads/戰術少女組-大頭貼.png" alt="Logo" class="w-[76px] h-[76px] object-cover group-hover:scale-105 transition-transform" />
					</a>
				</div>
				<div class="flex flex-col md:flex-row items-center gap-6 w-full md:w-auto md:ml-6 flex-1">
					<!-- ✅ 標題高度精準保持在 56px -->
					<a href="/" class="flex items-center h-[76px] text-[32px] md:text-[56px] font-black tracking-widest text-pink-500 whitespace-nowrap leading-none">
						<span>戰術少女<span class="text-white">研究室</span></span>
					</a>
					<div class="relative w-full md:w-72 flex-shrink-0 md:ml-auto">
						<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400 text-xs">⚡</div>
						<input type="text" id="tactical-search" placeholder="輸入關鍵字後按 Enter 搜尋..." class="w-full bg-blue-950/60 text-xs text-slate-200 pl-8 pr-10 py-2.5 rounded border border-blue-900/60 focus:outline-none focus:border-pink-500 placeholder-slate-400 transition-all font-medium" />
						<button id="search-submit-btn" class="absolute right-3 top-2.5 text-slate-400 hover:text-pink-500 transition-colors" title="執行搜尋">🔍</button>
						<div id="search-results" class="absolute right-0 top-full mt-2 w-full sm:w-80 bg-white border border-slate-200 rounded-xl shadow-2xl overflow-hidden hidden z-50 text-slate-900">
							<div class="bg-slate-50 px-3 py-2 border-b border-slate-100 text-[10px] font-bold text-slate-400 uppercase tracking-wider">即時情報預覽 (按 Enter 查看全部)</div>
							<ul id="results-list" class="divide-y divide-slate-100 max-h-60 overflow-y-auto"></ul>
						</div>
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-start text-sm font-bold py-3 px-4 gap-2">
				<nav class="flex space-x-6 whitespace-nowrap">
					<a href="/" class="text-pink-400 border-b-2 border-pink-500 pb-0.5">首頁通報</a>
					<a href="/category/軍事戰略" class="hover:text-pink-400 transition-colors">軍事戰略</a>
					<a href="/category/全民防衛" class="hover:text-pink-400 transition-colors">全民防衛</a>
					<a href="/category/戰術自訓" class="hover:text-pink-400 transition-colors">戰術自訓</a>
					<a href="/category/軍工產業" class="hover:text-pink-400 transition-colors">軍工產業</a>
					<a href="/category/軍風搜奇" class="hover:text-pink-400 transition-colors">軍風搜奇</a>
				</nav>
			</div>
		</header>

		<!-- 主要內容區 -->
		<main class="max-w-7xl mx-auto px-4 py-8 flex-grow w-full">
			
			<!-- 🚨 完美回歸：精選情報重大特報輪播 (Carousel) -->
			{carouselPosts.length > 0 && (
				<section class="relative mb-12 rounded-2xl overflow-hidden shadow-xl border border-slate-200 bg-slate-950 h-[300px] md:h-[460px] group">
					<div id="carousel-wrapper" class="relative w-full h-full whitespace-nowrap transition-transform duration-700 ease-out">
						{carouselPosts.map((post, index) => (
							<div class="inline-block w-full h-full relative whitespace-normal">
								{post.data.heroImage ? (
									<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover opacity-85" />
								) : (
									<div class="w-full h-full bg-gradient-to-br from-blue-950 to-slate-900" />
								)}
								<!-- 漸層暗化遮罩，突顯軍風文字標題 -->
								<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/40 to-transparent" />
								
								<!-- 精選情報內文標記 -->
								<div class="absolute bottom-0 left-0 w-full p-6 md:p-10 text-white flex flex-col justify-end">
									<span class="bg-pink-600 text-[10px] md:text-xs font-black px-2.5 py-1 rounded self-start mb-3 uppercase tracking-wider shadow-sm animate-pulse">
										🔥 重大精選特報
									</span>
									<h2 class="text-lg md:text-3xl font-black mb-2 md:mb-4 leading-tight tracking-tight hover:text-pink-400 transition-colors max-w-4xl line-clamp-2">
										<a href={`/blog/${post.slug}`}>{post.data.title}</a>
									</h2>
									<p class="text-xs md:text-sm text-slate-300 max-w-2xl line-clamp-2 hidden sm:block font-medium">
										{post.data.summary}
									</p>
								</div>
							</div>
						))}
					</div>

					<!-- 輪播左右切換箭頭 -->
					<button id="prev-btn" class="absolute left-4 top-1/2 -translate-y-1/2 bg-slate-900/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all z-10" title="上一則">‹</button>
					<button id="next-btn" class="absolute right-4 top-1/2 -translate-y-1/2 bg-slate-900/60 hover:bg-pink-600 text-white w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all z-10" title="下一則">›</button>

					<!-- 輪播位置指示燈圈 -->
					<div class="absolute bottom-4 right-6 flex space-x-2 z-10">
						{carouselPosts.map((_, i) => (
							<button data-index={i} class={`carousel-dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-pink-500 w-5' : 'bg-white/50'}`} title={`情報分頁 ${i + 1}`} />
						))}
					</div>
				</section>
			)}

			<!-- 下方常規通報清單 -->
			<h2 class="text-xl font-black text-slate-900 mb-6 border-l-4 border-pink-500 pl-3">📋 最新戰術通報清單</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{sortedPosts.map(post => (
					<article class="bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col">
						{post.data.heroImage && (
							<a href={`/blog/${post.slug}`} class="block overflow-hidden h-48 bg-slate-100">
								<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover hover:scale-102 transition-transform" />
							</a>
						)}
						<div class="p-5 flex flex-col flex-grow">
							<span class="text-[10px] bg-slate-100 text-slate-600 font-bold px-2 py-0.5 rounded self-start mb-3">{post.data.category}</span>
							<h3 class="text-base font-bold text-slate-900 leading-snug mb-2 line-clamp-2 hover:text-pink-600"><a href={`/blog/${post.slug}`}>{post.data.title}</a></h3>
							<p class="text-xs text-slate-500 line-clamp-3 mb-4 flex-grow">{post.data.summary}</p>
							<div class="text-[11px] text-slate-400 font-mono mt-auto pt-3 border-t border-slate-100">{new Date(post.data.date).toLocaleDateString('zh-TW')}</div>
						</div>
					</article>
				))}
			</div>
		</main>

		<!-- 🛰️ 完整 Footer 區塊 -->
		<footer class="bg-[#003764] text-slate-300 border-t border-blue-900 text-xs mt-20 pt-10 pb-8 text-center">
			<div class="max-w-7xl mx-auto px-4 mb-4 flex flex-wrap justify-center gap-x-6 gap-y-2 text-slate-400 font-medium">
				<a href="/about" class="hover:text-pink-400 transition-colors">關於我們</a>
				<a href="/contact" class="hover:text-pink-400 transition-colors">聯繫我們</a>
				<a href="/privacy" class="hover:text-pink-400 transition-colors">隱私政策</a>
				<a href="/terms" class="hover:text-pink-400 transition-colors">服務條款</a>
				<a href="/cookie-policy" class="hover:text-pink-400 transition-colors">Cookie 政策</a>
			</div>
			<p>© {currentYear} 戰術少女研究室 TACTICAL SHOJO NEWS. All Rights Reserved.</p>
		</footer>

		<!-- 搜尋與輪播自動化驅動腳本 -->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				// -------------------------
				// 1. 輪播功能核心邏輯 (Carousel)
				// -------------------------
				const wrapper = document.getElementById('carousel-wrapper');
				const dots = document.querySelectorAll('.carousel-dot');
				const prevBtn = document.getElementById('prev-btn');
				const nextBtn = document.getElementById('next-btn');
				
				if (wrapper && dots.length > 0) {
					let currentIndex = 0;
					const totalSlides = dots.length;
					let intervalId = null;

					const updateCarousel = (index) => {
						currentIndex = (index + totalSlides) % totalSlides;
						wrapper.style.transform = `translateX(-${currentIndex * 100}%)`;
						
						// 更新燈圈動態視覺
						dots.forEach((dot, i) => {
							if (i === currentIndex) {
								dot.classList.add('bg-pink-500', 'w-5');
								dot.classList.remove('bg-white/50');
							} else {
								dot.classList.remove('bg-pink-500', 'w-5');
								dot.classList.add('bg-white/50');
							}
						});
					};

					const startAutoPlay = () => {
						stopAutoPlay();
						intervalId = setInterval(() => updateCarousel(currentIndex + 1), 6000);
					};

					const stopAutoPlay = () => {
						if (intervalId) clearInterval(intervalId);
					};

					// 箭頭點擊與燈圈綁定
					prevBtn?.addEventListener('click', () => { updateCarousel(currentIndex - 1); startAutoPlay(); });
					nextBtn?.addEventListener('click', () => { updateCarousel(currentIndex + 1); startAutoPlay(); });
					dots.forEach(dot => {
						dot.addEventListener('click', (e) => {
							const targetIdx = parseInt(e.target.getAttribute('data-index') || '0', 10);
							updateCarousel(targetIdx);
							startAutoPlay();
						});
					});

					// 滑鼠滑入滑出控制
					wrapper.parentElement?.addEventListener('mouseenter', stopAutoPlay);
					wrapper.parentElement?.addEventListener('mouseleave', startAutoPlay);

					// 啟動自動巡航
					startAutoPlay();
				}

				// -------------------------
				// 2. 搜尋驅動邏輯
				// -------------------------
				const searchInput = document.getElementById('tactical-search');
				const searchResults = document.getElementById('search-results');
				const resultsList = document.getElementById('results-list');
				const submitBtn = document.getElementById('search-submit-btn');

				if (!searchInput || !searchResults || !resultsList) return;

				const redirectToSearchPage = () => {
					const keyword = searchInput.value.trim();
					if (keyword.length > 0) window.location.href = `/search?q=${encodeURIComponent(keyword)}`;
				};

				searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); redirectToSearchPage(); } });
				submitBtn?.addEventListener('click', (e) => { e.preventDefault(); redirectToSearchPage(); });
				document.addEventListener('click', (e) => { if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) searchResults.classList.add('hidden'); });

				searchInput.addEventListener('input', (e) => {
					const keyword = e.target.value.toLowerCase().trim();
					if (keyword.length < 1) { searchResults.classList.add('hidden'); return; }
					const posts = window.__TACTICAL_POSTS__ || [];
					const filtered = posts.filter(post => post.title.toLowerCase().includes(keyword) || post.summary.toLowerCase().includes(keyword)).slice(0, 5);
					resultsList.innerHTML = '';
					if (filtered.length === 0) {
						resultsList.innerHTML = `<li class="px-4 py-3 text-xs text-slate-400 text-center font-medium">❌ 未尋獲相關情報 (按 Enter 查看全部)</li>`;
					} else {
						filtered.forEach(post => {
							const li = document.createElement('li');
							li.innerHTML = `<a href="/blog/${post.slug}" class="block px-4 py-2.5 hover:bg-slate-50 transition-colors group"><div class="text-xs font-bold text-slate-900 group-hover:text-pink-600 transition-colors line-clamp-1">${post.title}</div></a>`;
							resultsList.appendChild(li);
						});
					}
					searchResults.classList.remove('hidden');
				});
			});
		</script>
	</body>
</html>