---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const allAuthors = await getCollection('authors');

// 建立作者對照表
const authorMap = Object.fromEntries(allAuthors.map(a => [a.id, a.data]));

const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const heroPosts = sortedPosts.filter(p => p.data.isHeroBanner);
const hotTopicPosts = sortedPosts.filter(p => p.data.isHotTopic);
const featuredPosts = sortedPosts.filter(p => p.data.isFeatured);
const latestPosts = sortedPosts.slice(0, 12); // 發文量大，首頁一次展示 12 篇

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>戰術少女研究室 | TACTICAL SHOJO NEWS</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">

		<header class="bg-[#0f172a] text-white sticky top-0 z-50 shadow-lg border-b-2 border-pink-600">
			<div class="max-w-7xl mx-auto px-4">
				<div class="flex flex-col md:flex-row justify-between items-center py-4 gap-4 border-b border-slate-800">
					<a href="/" class="text-2xl font-black tracking-widest text-pink-500 flex items-center gap-2">
						⚔️ <span>戰術少女<span class="text-white">研究室</span></span>
					</a>
					<div class="relative w-full md:w-72">
						<input type="text" placeholder="搜尋軍事戰略、戰術自訓..." class="w-full bg-slate-800 text-xs text-slate-200 pl-4 pr-10 py-2.5 rounded border border-slate-700 focus:outline-none focus:border-pink-500" />
						<span class="absolute right-3 top-2.5 text-slate-400">🔍</span>
					</div>
				</div>
				<nav class="flex flex-wrap items-center justify-between text-sm font-bold py-3 overflow-x-auto">
					<div class="flex space-x-6 whitespace-nowrap">
						<a href="/" class="text-pink-500">首頁通報</a>
						<a href="#" class="hover:text-pink-400">軍事戰略</a>
						<a href="#" class="hover:text-pink-400">全民防衛</a>
						<a href="#" class="hover:text-pink-400">戰術自訓</a>
						<a href="#" class="hover:text-pink-400">軍工產業</a>
						<a href="#" class="hover:text-pink-400">軍風搜奇</a>
					</div>
					{hotTopicPosts.length > 0 && (
						<div class="flex items-center gap-2 text-xs bg-pink-600 px-3 py-1 rounded-full text-white animate-pulse mt-2 lg:mt-0">
							<span>🔥 焦點特報：</span>
							<a href={`/blog/${hotTopicPosts[0].slug}`} class="underline font-medium">{hotTopicPosts[0].data.title}</a>
						</div>
					)}
				</nav>
			</div>
		</header>

		<div class="max-w-7xl mx-auto px-4 my-4">
			<div class="bg-slate-200 border border-slate-300 text-slate-400 text-xs text-center py-4 rounded tracking-widest font-mono">
				【廣告版面 PRE-SLOT / SUPPORT GOOGLE ADSENSE】
			</div>
		</div>

		<main class="max-w-7xl mx-auto px-4 py-6">
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-12">
				<div class="lg:col-span-2">
					{heroPosts.length > 0 ? (
						<div class="relative bg-slate-900 rounded-xl overflow-hidden group shadow-md aspect-[16/9]">
							<img src={heroPosts[0].data.heroImage || "https://images.unsplash.com/photo-1508614589041-895b88991e3e?q=80&w=1200"} class="w-full h-full object-cover opacity-75 group-hover:scale-101 transition duration-500" alt="Hero" />
							<div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-slate-950 via-slate-900/60 to-transparent text-white">
								<span class="bg-pink-600 text-xs font-black px-2.5 py-1 rounded">{heroPosts[0].data.category}</span>
								<h2 class="text-xl md:text-3xl font-black mt-3 hover:text-pink-400 transition leading-tight">
									<a href={`/blog/${heroPosts[0].slug}`}>{heroPosts[0].data.title}</a>
								</h2>
								<p class="text-slate-300 text-sm mt-2 line-clamp-2 hidden md:block">{heroPosts[0].data.summary}</p>
							</div>
						</div>
					) : (
						<div class="bg-slate-800 text-slate-400 rounded-xl p-12 text-center font-medium">請在後台將文章勾選「登上頭條大圖輪播區」</div>
					)}
				</div>
				<div class="bg-white p-5 rounded-xl shadow-sm border border-slate-200 flex flex-col justify-between">
					<div>
						<h3 class="text-base font-black border-l-4 border-pink-600 pl-2 mb-4 text-slate-900">⚡ 本期焦點推薦</h3>
						<ul class="space-y-4">
							{featuredPosts.slice(0, 5).map((post, idx) => (
								<li class="flex gap-3 items-start border-b border-slate-100 pb-3 last:border-0 last:pb-0">
									<span class="text-xl font-black text-slate-300 italic">0{idx+1}</span>
									<div>
										<a href={`/blog/${post.slug}`} class="font-bold text-sm text-slate-800 hover:text-pink-600 line-clamp-2">{post.data.title}</a>
										<span class="text-[10px] text-slate-400 block mt-1">{new Date(post.data.date).toLocaleDateString('zh-TW')}</span>
									</div>
								</li>
							))}
						</ul>
					</div>
					<div class="bg-slate-50 border border-dashed border-slate-300 text-slate-400 text-[10px] text-center py-4 mt-4 rounded font-mono">
						【廣告版面 SIDEBAR-SLOT】
					</div>
				</div>
			</div>

			<section class="mb-12">
				<h3 class="text-lg font-black border-l-4 border-slate-900 pl-2 mb-6 text-slate-900">📡 最新情報觀測發布</h3>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{latestPosts.map((post) => (
						<article class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow border border-slate-200 flex flex-col justify-between transition-all">
							<div>
								<div class="relative aspect-[16/10] bg-slate-100">
									<img src={post.data.heroImage || "https://images.unsplash.com/photo-1579546929518-9e396f3cc809?q=80&w=600"} class="w-full h-full object-cover" alt="Thumb" />
									<span class="absolute top-3 left-3 bg-slate-900/90 text-white text-[10px] font-black px-2 py-0.5 rounded shadow-sm">{post.data.category}</span>
								</div>
								<div class="p-4">
									<h4 class="font-bold text-base text-slate-900 hover:text-pink-600 transition line-clamp-2 mb-2">
										<a href={`/blog/${post.slug}`}>{post.data.title}</a>
									</h4>
									<p class="text-slate-600 text-xs line-clamp-3 leading-relaxed">{post.data.summary}</p>
								</div>
							</div>
							<div class="px-4 pb-4 pt-3 border-t border-slate-100 flex justify-between items-center text-xs text-slate-400">
								<span class="font-medium text-slate-500">
									✍️ {post.data.authors.map(id => authorMap[id]?.name || id).join(', ')}
								</span>
								<span>{new Date(post.data.date).toLocaleDateString('zh-TW', {timeZone: 'Asia/Taipei'})}</span>
							</div>
						</article>
					))}
				</div>
			</section>
		</main>

		<footer class="bg-[#0f172a] text-slate-400 text-xs mt-20 border-t-4 border-pink-600">
			<div class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
				<div>
					<h4 class="text-white text-base font-black mb-4">⚔️ 戰術少女研究室</h4>
					<p class="leading-relaxed text-slate-400 text-xs">配合現代化國防轉型與民間自訓風潮，提供精準、硬核、可信任的軍事戰略、全民防衛及無人機防禦情報。我們致力於打造最高防護力的新聞學社群。</p>
				</div>
				<div>
					<h4 class="text-white text-sm font-bold mb-4">條款與合規信任聲明</h4>
					<div class="grid grid-cols-2 gap-2">
						<a href="#" class="hover:text-white">關於我們</a>
						<a href="#" class="hover:text-white">聯繫我們</a>
						<a href="#" class="hover:text-white">隱私政策</a>
						<a href="#" class="hover:text-white">服務條款</a>
						<a href="#" class="hover:text-white">Cookie 政策</a>
					</div>
				</div>
				<div>
					<h4 class="text-white text-sm font-bold mb-4">社群戰術情報鏈</h4>
					<div class="flex space-x-4 text-lg">
						<a href="#" class="hover:text-white">🌐</a><a href="#" class="hover:text-white">📺</a><a href="#" class="hover:text-white">💬</a><a href="#" class="hover:text-white">📸</a>
					</div>
				</div>
			</div>
			<div class="bg-[#0b0f19] text-center py-4 text-slate-500 border-t border-slate-800">
				Copyright &copy; {currentYear} 戰術少女研究室 (TACTICAL SHOJO). All Rights Reserved. (GMT+8 台北時間自動校正)
			</div>
		</footer>
	</body>
</html>
