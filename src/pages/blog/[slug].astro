---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// ✍️ 靜態作者資料庫
const authorDatabase = {
  "戰術小編": {
    name: "戰術小編",
    avatar: "/images/uploads/戰術少女組-大頭貼.png",
    bio: "負責本站日常戰術情報通報與資訊整合，提供最即時的消息",
    slug: "editor"
  },
  "節目企劃": {
    name: "節目企劃",
    avatar: "/images/uploads/戰術少女組-大頭貼.png",
    bio: "節目企劃，常跑現場也是整個戰術少女組的專案負責人",
    slug: "producer"
  },
  "Yelena": {
    name: "Yelena",
    avatar: "/images/uploads/Yelena.jpg",
    bio: "政治產業從業者，負責政治相關議題的解釋與評論，欸欸我本人沒有頭像這麼兇啦",
    slug: "yelena"
  },
  "Urica": {
    name: "Urica",
    avatar: "/images/uploads/Urica.jpg",
    bio: "希望在狂風暴雨的時候也能懶洋洋地過日子，負責民防相關議題的處理",
    slug: "urica"
  },
  "Nina": {
    name: "Nina",
    avatar: "/images/uploads/Nina.png",
    bio: "喜歡pewpew咻咻跟酷酷武器94我(◕ܫ◕)",
    slug: "nina"
  },
  "Grace": {
    name: "Grace",
    avatar: "/images/uploads/Grace.jpg",
    bio: "喜歡史明「要先做一個好的人，再成為台灣人」，關注語言與歷史",
    slug: "grace"
  },
  "客座投稿": {
    name: "客座投稿",
    avatar: "/images/uploads/戰術少女組-大頭貼.png",
    bio: "來自各方專家、產業人士、第一線勤務人員的珍貴經驗分享",
    slug: "guest"
  }
};

// 🎯 核心攔截邏輯：優先從 tags 陣列中尋找作者
const postTags = entry.data.tags || [];
const postTitle = entry.data.title || "";
let currentAuthor = authorDatabase["戰術小編"];

const lowerTags = postTags.map(tag => tag.toLowerCase());
const lowerTitle = postTitle.toLowerCase();

if (lowerTags.includes("nina") || lowerTitle.includes("nina")) {
  currentAuthor = authorDatabase["Nina"];
} else if (lowerTags.includes("yelena") || lowerTitle.includes("yelena")) {
  currentAuthor = authorDatabase["Yelena"];
} else if (lowerTags.includes("urica") || lowerTitle.includes("urica")) {
  currentAuthor = authorDatabase["Urica"];
} else if (lowerTags.includes("grace") || lowerTitle.includes("grace")) {
  currentAuthor = authorDatabase["Grace"];
} else if (lowerTags.includes("節目企劃") || lowerTags.includes("企劃") || lowerTitle.includes("節目企劃") || lowerTitle.includes("企劃")) {
  currentAuthor = authorDatabase["節目企劃"];
} else if (lowerTags.includes("客座") || lowerTags.includes("投稿") || lowerTags.includes("專家") || lowerTitle.includes("客座") || lowerTitle.includes("投稿") || lowerTitle.includes("專家")) {
  currentAuthor = authorDatabase["客座投稿"];
} else if (lowerTags.includes("小編") || lowerTags.includes("戰術小編") || lowerTitle.includes("小編") || lowerTitle.includes("戰術小編")) {
  currentAuthor = authorDatabase["戰術小編"];
}

const displayTags = postTags.filter(tag => {
  const t = tag.toLowerCase();
  return !["nina", "yelena", "urica", "grace", "節目企劃", "企劃", "客座", "投稿", "專家", "戰術小編", "小編"].includes(t);
});

const formattedDate = new Date(entry.data.date).toLocaleString('zh-TW', {
  timeZone: 'Asia/Taipei',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hour12: false
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": entry.data.title,
  "image": [ entry.data.heroImage || "https://tacticalshojo.com/default-share.jpg" ],
  "datePublished": entry.data.date.toISOString(),
  "dateModified": entry.data.date.toISOString(),
  "author": [{
    "@type": "Person",
    "name": currentAuthor.name,
    "url": `https://tacticalshojo.com/authors/${currentAuthor.slug}`
  }]
};

// 🌟 新增邏輯：撈取並過濾出同作者的最新三篇文章
const allBlogEntries = await getCollection('blog');

const authorRecentPosts = allBlogEntries
  .filter(post => {
    // 排除目前這篇文章
    if (post.slug === entry.slug) return false;
    
    // 判定文章作者是否與當前作者相同 (使用相同的攔截邏輯)
    const tags = (post.data.tags || []).map(t => t.toLowerCase());
    const title = (post.data.title || "").toLowerCase();
    
    if (currentAuthor.name === "Nina") return tags.includes("nina") || title.includes("nina");
    if (currentAuthor.name === "Yelena") return tags.includes("yelena") || title.includes("yelena");
    if (currentAuthor.name === "Urica") return tags.includes("urica") || title.includes("urica");
    if (currentAuthor.name === "Grace") return tags.includes("grace") || title.includes("grace");
    if (currentAuthor.name === "節目企劃") return tags.includes("節目企劃") || tags.includes("企劃") || title.includes("節目企劃") || title.includes("企劃");
    if (currentAuthor.name === "客座投稿") return tags.includes("客座") || tags.includes("投稿") || tags.includes("專家") || title.includes("客座") || title.includes("投稿") || title.includes("專家");
    if (currentAuthor.name === "戰術小編") return tags.includes("戰術小編") || tags.includes("小編") || title.includes("戰術小編") || title.includes("小編") || (!tags.some(t => ["nina", "yelena", "urica", "grace", "節目企劃", "企劃", "客座", "投稿", "專家"].includes(t)) && !["nina", "yelena", "urica", "grace", "節目企劃", "企劃", "客座", "投稿", "專家"].some(k => title.includes(k)));
    
    return false;
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()) // 依日期新到舊排序
  .slice(0, 3); // 截取最新 3 篇
---

<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{entry.data.title} | 戰術少女研究室</title>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">
		
		<div class="bg-[#0f172a] text-white py-3.5 px-4 border-b-2 border-pink-500">
			<div class="max-w-4xl mx-auto flex justify-between items-center">
				<a href="/" class="font-black text-pink-500 tracking-widest text-sm">⚔️ 戰術少女研究室</a>
				<a href="/" class="text-xs text-slate-400 hover:text-white">← 返回首頁通報</a>
			</div>
		</div>

		<main class="max-w-3xl mx-auto px-4 py-8">
			<div class="mb-4 flex flex-wrap gap-2">
				<span class="bg-pink-100 text-pink-700 text-xs font-black px-2.5 py-1 rounded">{entry.data.category}</span>
				
				{displayTags.map(tag => (
					<span class="bg-slate-200 text-slate-700 text-xs font-medium px-2 py-1 rounded">#{tag}</span>
				))}
			</div>
			
			<h1 class="text-2xl md:text-4xl font-black text-slate-900 tracking-tight leading-tight mb-4">{entry.data.title}</h1>
			
			<div class="flex flex-wrap items-center gap-4 text-xs text-slate-400 border-b border-slate-200 pb-4 mb-6">
				<span class="font-bold text-slate-700">✍️ 記者：<a href={`/authors/${currentAuthor.slug}`} class="text-pink-600 hover:underline">{currentAuthor.name}</a></span>
				<span>🕒 發布時間：{formattedDate} (台灣時區 GMT+8)</span>
			</div>

			<div class="bg-slate-100 border text-slate-400 text-xs text-center py-3 my-4 rounded font-mono">
				【廣告版面 ARTICLE-TOP-ADS】
			</div>

			<p class="text-slate-700 font-medium text-base bg-slate-100 border-l-4 border-slate-400 p-4 rounded-r mb-8 leading-relaxed italic">
				【摘要特報】{entry.data.summary}
			</p>

			{entry.data.heroImage && (
				<figure class="mb-8 border border-slate-200 rounded-xl overflow-hidden bg-white shadow-sm">
					<img src={entry.data.heroImage} class="w-full h-auto object-cover max-h-[450px]" alt="Hero" />
					{entry.data.heroImageCaption && (
						<figcaption class="bg-slate-50 text-xs text-slate-500 p-3 border-t text-center font-medium">📷 {entry.data.heroImageCaption}</figcaption>
					)}
				</figure>
			)}

			<article class="text-slate-800 leading-relaxed space-y-6 text-[1.05rem]">
				<Content />
			</article>

			{entry.data.gallery && entry.data.gallery.length > 0 && (
				<section class="mt-12 pt-8 border-t border-slate-200">
					<h3 class="text-sm font-black text-slate-900 mb-4">📋 相關戰術現場影像通報</h3>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
						{entry.data.gallery.map((item) => (
							<figure class="border border-slate-200 rounded-lg bg-white overflow-hidden shadow-sm">
								<img src={item.image} class="w-full h-40 object-cover" alt="Gallery" />
								<figcaption class="p-2.5 text-xs text-slate-500 bg-slate-50 border-t">{item.caption}</figcaption>
							</figure>
						))}
					</div>
				</section>
			)}

			<div class="bg-slate-100 border text-slate-400 text-xs text-center py-3 my-8 rounded font-mono">
				【廣告版面 ARTICLE-BOTTOM-ADS】
			</div>

            <!-- 🌟 升級版：大尺寸響應式作者卡片與最新文章區塊 -->
			<section class="mt-12 pt-8 border-t border-slate-200">
				<div class="bg-white border border-slate-200 rounded-xl p-6 md:p-8 flex flex-col md:flex-row gap-8 shadow-sm">
                    
                    <!-- 左側：大尺寸作者頭像 (桌機版固定 250px 寬，手機版置中) -->
					<div class="flex-shrink-0 flex justify-center md:justify-start">
					    <img src={currentAuthor.avatar} class="w-48 h-48 md:w-[250px] md:h-[250px] rounded-2xl object-cover bg-slate-100 border-2 border-slate-200 shadow-sm" alt={`${currentAuthor.name} Avatar`} />
					</div>
                    
                    <!-- 右側：作者簡介與最新文章導流 -->
					<div class="flex-grow flex flex-col justify-center">
                        <div class="mb-4 text-center md:text-left">
                            <h3 class="text-xs font-bold text-pink-600 tracking-wider mb-1 uppercase">About Author</h3>
						    <h4 class="font-black text-2xl text-slate-900">
							    <a href={`/authors/${currentAuthor.slug}`} class="hover:text-pink-600 transition-colors">{currentAuthor.name}</a>
						    </h4>
						    <p class="text-sm text-slate-600 mt-3 leading-relaxed">{currentAuthor.bio}</p>
                        </div>

                        <!-- 該作者最新三篇文章列表 -->
                        {authorRecentPosts.length > 0 && (
                            <div class="mt-4 pt-4 border-t border-slate-100">
                                <h5 class="text-xs font-bold text-slate-500 mb-3 uppercase tracking-wider text-center md:text-left">最新文章</h5>
                                <ul class="space-y-2">
                                    {authorRecentPosts.map(post => (
                                        <li class="flex items-start gap-2 group">
                                            <span class="text-pink-400 mt-0.5">▸</span>
                                            <a href={`/blog/${post.slug}`} class="text-sm text-slate-700 font-medium group-hover:text-pink-600 group-hover:underline line-clamp-1 transition-colors">
                                                {post.data.title}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
					</div>

				</div>
			</section>

			<section class="mt-8 bg-white border border-slate-200 rounded-xl p-4 text-center text-xs text-slate-400">
				💬 讀者評論互動區已準備完畢（驗收後可一鍵無縫掛載 Disqus 或 Giscus 外掛）。
			</section>
		</main>
	</body>
</html>