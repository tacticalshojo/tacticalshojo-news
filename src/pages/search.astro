---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 撈取文章與作者資料
const allPosts = await getCollection('blog');
const allAuthors = await getCollection('authors');
const authorMap = Object.fromEntries(allAuthors.map(a => [a.id, a.data]));

const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// 整理供搜尋頁面使用的完整橋樑資料
const searchBridge = sortedPosts.map(post => ({
  title: post.data.title || "",
  summary: post.data.summary || "",
  category: post.data.category || "未分類",
  heroImage: post.data.heroImage || "",
  date: post.data.date instanceof Date ? post.data.date.toISOString().split('T')[0] : String(post.data.date).split(' ')[0],
  authorName: authorMap[post.data.authors?.[0]]?.name || '編輯部',
  slug: post.slug
}));
---

<BaseLayout 
  title="情報檢索結果 | 戰術少女研究室" 
  description="搜尋戰術少女研究室全站關於民防、軍事戰略與戰術自訓的通報紀錄。"
>
  <!-- 將搜尋專用的完整資料傳給全域 window 物件 -->
  <script define:vars={{ searchBridge }}>
    window.__SEARCH_PAGE_POSTS__ = searchBridge;
  </script>

  <div class="max-w-7xl mx-auto my-6">
    <!-- 頁面標題與搜尋狀態 -->
    <div class="mb-8 border-b border-slate-200 pb-4">
      <h2 class="text-2xl font-black border-l-4 border-pink-600 pl-3 mb-2 tracking-wider text-slate-900">
        🔍 情報檢索結果
      </h2>
      <p id="search-query-title" class="text-slate-500 text-xs font-mono">
        正在初始化戰術資料庫...
      </p>
    </div>

    <!-- 搜尋結果卡片展示區 -->
    <div id="results-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- 由前端 JavaScript 動態渲染結果 -->
    </div>
  </div>

  <!-- 搜尋頁面專屬驅動邏輯 -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.getElementById('results-grid');
      const queryTitle = document.getElementById('search-query-title');
      const headerSearchInput = document.getElementById('tactical-search');

      // 從 URL 抓取關鍵字 ?q=xxx
      const getQuery = () => new URLSearchParams(window.location.search).get('q') || '';
      
      // 核心渲染邏輯
      const renderResults = (query) => {
        if (!grid || !queryTitle) return;

        // 同步修改 Header 的搜尋框文字
        if (headerSearchInput) {
          headerSearchInput.value = query;
        }

        if (!query.trim()) {
          queryTitle.textContent = '未輸入檢索關鍵字，請於上方搜尋框輸入。';
          grid.innerHTML = `
            <div class="col-span-full bg-white border border-slate-200 rounded-xl p-12 text-center text-slate-400 text-sm font-medium shadow-sm">
              💡 請於上方搜尋框輸入關鍵字進行情報檢索。
            </div>
          `;
          return;
        }

        queryTitle.innerHTML = `當前檢索關鍵字：<span class="text-pink-600 font-bold font-sans">"${query}"</span>`;

        // 優先讀取搜尋頁專用的完整資料，若無則讀取 Layout 提供的基礎資料
        const posts = window.__SEARCH_PAGE_POSTS__ || window.__TACTICAL_POSTS__ || [];
        const filtered = posts.filter(post => 
          (post.title && post.title.toLowerCase().includes(query.toLowerCase())) || 
          (post.summary && post.summary.toLowerCase().includes(query.toLowerCase())) ||
          (post.category && post.category.toLowerCase().includes(query.toLowerCase()))
        );

        if (filtered.length === 0) {
          grid.innerHTML = `
            <div class="col-span-full bg-white border border-slate-200 rounded-xl p-12 text-center text-slate-400 text-sm font-medium shadow-sm">
              ❌ 未尋獲與 "${query}" 相關的戰術通報紀錄。
            </div>
          `;
          return;
        }

        // 動態生成文章卡片
        grid.innerHTML = filtered.map(post => `
          <article class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col hover:shadow-md transition duration-300">
            ${post.heroImage ? `
              <div class="h-48 overflow-hidden bg-slate-100">
                <a href="/blog/${post.slug}">
                  <img src="${post.heroImage}" alt="${post.title}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
                </a>
              </div>
            ` : ''}
            <div class="p-5 flex-1 flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-bold text-pink-600">${post.category || '未分類'}</span>
                  ${post.date ? `<span class="text-[10px] text-slate-400 font-mono">${post.date}</span>` : ''}
                </div>
                <h3 class="font-bold text-lg text-slate-900 mb-2 line-clamp-2 hover:text-pink-600">
                  <a href="/blog/${post.slug}">${post.title}</a>
                </h3>
                <p class="text-slate-500 text-xs line-clamp-3 mb-4 leading-relaxed">${post.summary || ''}</p>
              </div>
              <div class="pt-3 border-t border-slate-100 flex items-center justify-between text-[11px] text-slate-400">
                <span>筆者：${post.authorName || '編輯部'}</span>
                <a href="/blog/${post.slug}" class="text-pink-600 font-bold hover:underline">閱讀通報 →</a>
              </div>
            </div>
          </article>
        `).join('');
      };

      // 頁面載入時先執行一次渲染
      const currentQ = getQuery();
      renderResults(currentQ);

      // 監聽網址上一頁/下一頁變更事件
      window.addEventListener('popstate', () => {
        renderResults(getQuery());
      });
    });
  </script>
</BaseLayout>