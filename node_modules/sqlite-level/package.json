{
  "name": "sqlite-level",
  "description": "sqlite backed abstract-level database for Node.js",
  "version": "2.1.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "keywords": [
    "level",
    "leveldb",
    "leveldown",
    "levelup",
    "memory",
    "sqlite"
  ],
  "bugs": {
    "url": "https://github.com/tinacms/sqlite-level/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinacms/sqlite-level.git"
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "CHANGELOG.md",
    "README.md"
  ],
  "dependencies": {
    "abstract-level": "^1.0.4",
    "better-sqlite3": "^12.10.0",
    "module-error": "^1.0.2"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit",
    "docs": "npx typedoc",
    "version": "pnpm exec changeset version"
  }
}